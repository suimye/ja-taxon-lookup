{
  "name": "jsnentax",
  "version": "1.0.0",
  "description": "日本語名から種名・英名・Taxidを取得",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "jp.dbcls.jsnentax",
    "productName": "JSNENTax",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
